generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SlotStatus {
  AVAILABLE
  HELD
  BOOKED
  EXPIRED
  COMPLETED
}

enum ReservationStatus {
  PENDING_APPROVAL
  CONFIRMED
  CANCELLED
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String
  walletBalance Decimal       @default(150) @db.Decimal(12, 2)
  createdAt     DateTime      @default(now())
  venues        Venue[]
  heldSlots     TimeSlot[]    @relation("HeldBy")
  participations Participant[]
}

model Venue {
  id           String             @id @default(uuid())
  name         String
  address      String
  sportTypes   String[]
  pricePerHour Decimal            @db.Decimal(12, 2)
  capacity     Int
  ownerId      String
  owner        User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  rules        AvailabilityRule[]
  slots        TimeSlot[]
  reservations Reservation[]
}

model AvailabilityRule {
  id        String @id @default(uuid())
  venueId   String
  venue     Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  dayOfWeek Int    // 0-6
  startTime String // "08:00"
  endTime   String // "22:00"
}

model TimeSlot {
  id            String        @id @default(uuid())
  venueId       String
  venue         Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  startTime     DateTime
  endTime       DateTime
  status        SlotStatus    @default(AVAILABLE)
  heldById      String?
  heldBy        User?         @relation("HeldBy", fields: [heldById], references: [id])
  heldExpiresAt DateTime?
  reservation   Reservation?
  @@unique([venueId, startTime])
  @@index([status, endTime])
}

model Reservation {
  id           String            @id @default(uuid())
  venueId      String
  venue        Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  slotId       String            @unique
  slot         TimeSlot          @relation(fields: [slotId], references: [id])
  status       ReservationStatus @default(PENDING_APPROVAL)
  createdAt    DateTime          @default(now())
  participants Participant[]
}

model Participant {
  id              String      @id @default(uuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  sharePercentage Float
  hasAccepted     Boolean     @default(false)
  @@unique([reservationId, userId])
}
